/* === HERO SECTION - FULL SIZE IMAGE === */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

.hero-section {
  position: relative;
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a1a 0%, #1a1a3e 50%, #0d0d2b 100%);
  display: flex;
  align-items: center;
  overflow: hidden;
  font-family: 'Inter', sans-serif;
}

/* Left Content - Positioned Over Image */
.hero-left {
  position: relative;
  z-index: 2;
  padding: 2rem 4rem;
  padding-left: 6rem;
  max-width: 60%;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.hero-title {
  font-size: 5rem;
  font-weight: 900;
  background: linear-gradient(135deg, #00d4ff 0%, #0099cc 50%, #00ffcc 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.03em;
  margin: 0;
  line-height: 1;
}

.hero-subtitle {
  font-size: 2.2rem;
  font-weight: 600;
  color: #e8e8ff;
  letter-spacing: 0.02em;
  margin: 0.25rem 0 0 0;
}

.hero-tagline {
  font-size: 1.5rem;
  font-weight: 400;
  color: #8888a0;
  margin: 0.5rem 0 1.5rem 0;
  line-height: 1.5;
}

/* Navigation Buttons */
.hero-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.85rem;
  margin: 0.5rem 0;
}

.hero-nav-btn {
  background: rgba(0, 212, 255, 0.1);
  border: 1px solid rgba(0, 212, 255, 0.25);
  color: #00d4ff;
  padding: 0.75rem 1.5rem;
  border-radius: 50px;
  font-size: 1.05rem;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.3s ease;
  display: inline-block;
}

.hero-nav-btn:hover {
  background: rgba(0, 212, 255, 0.2);
  border-color: rgba(0, 212, 255, 0.5);
  transform: translateY(-2px);
  box-shadow: 0 5px 20px rgba(0, 212, 255, 0.2);
  color: #fff;
}

/* Resume Button */
.hero-resume-btn {
  background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
  color: #0a0a1a;
  padding: 1.1rem 2.2rem;
  border-radius: 50px;
  font-size: 1.15rem;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.3s ease;
  border: none;
  cursor: pointer;
  margin-top: 1.5rem;
  width: fit-content;
}

.hero-resume-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(0, 212, 255, 0.3);
}

/* Right Image - Full Size with Blend */
.hero-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 58%;
  height: 100%;
  z-index: 1;
}

.hero-img-container {
  width: 100%;
  height: 100%;
  position: relative;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 15%;
  /* Gradient fade blending on left side */
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 25%, black 100%);
  mask-image: linear-gradient(to right, transparent 0%, black 25%, black 100%);
}

/* Responsive */
@media (max-width: 1200px) {
  .hero-left {
    padding-left: 4rem;
    max-width: 55%;
  }

  .hero-title {
    font-size: 4rem;
  }

  .hero-subtitle {
    font-size: 1.8rem;
  }

  .hero-tagline {
    font-size: 1.3rem;
  }

  .hero-right {
    width: 55%;
  }
}

@media (max-width: 992px) {
  .hero-left {
    padding: 2rem 3rem;
    max-width: 60%;
  }

  .hero-title {
    font-size: 3.2rem;
  }

  .hero-subtitle {
    font-size: 1.5rem;
  }

  .hero-tagline {
    font-size: 1.1rem;
  }

  .hero-nav-btn {
    padding: 0.6rem 1.2rem;
    font-size: 0.95rem;
  }

  .hero-right {
    width: 50%;
  }

  .hero-img {
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 35%, black 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 35%, black 100%);
  }
}

@media (max-width: 768px) {
  .hero-section {
    flex-direction: column;
    min-height: auto;
    padding: 5rem 1.5rem 2rem;
  }

  .hero-left {
    position: relative;
    max-width: 100%;
    padding: 0;
    text-align: center;
    align-items: center;
    gap: 1rem;
  }

  .hero-title {
    font-size: 3rem;
  }

  .hero-subtitle {
    font-size: 1.35rem;
  }

  .hero-tagline {
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .hero-nav {
    justify-content: center;
  }

  .hero-nav-btn {
    padding: 0.6rem 1.1rem;
    font-size: 0.9rem;
  }

  .hero-resume-btn {
    padding: 0.9rem 1.75rem;
    font-size: 1rem;
    margin-top: 1rem;
  }

  .hero-right {
    position: relative;
    width: 100%;
    height: 350px;
    margin-top: 2rem;
  }

  .hero-img {
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 100%);
    border-radius: 12px;
    object-position: center 10%;
  }
}

@media (max-width: 480px) {
  .hero-section {
    padding: 4rem 1rem 2rem;
  }

  .hero-title {
    font-size: 2.5rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
  }

  .hero-tagline {
    font-size: 1rem;
  }

  .hero-nav {
    gap: 0.5rem;
  }

  .hero-nav-btn {
    padding: 0.5rem 0.9rem;
    font-size: 0.85rem;
  }

  .hero-resume-btn {
    padding: 0.8rem 1.5rem;
    font-size: 0.95rem;
  }

  .hero-right {
    height: 280px;
  }
}
